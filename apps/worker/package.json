{
  "name": "@tiktok-clip/worker",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "uv run uvicorn src.main:app --host 0.0.0.0 --port 8000 --reload",
    "start": "uv run uvicorn src.main:app --host 0.0.0.0 --port 8000",
    "worker": "uv run celery -A src.celery_app worker --loglevel=info --concurrency=2",
    "lint": "uv run ruff check src tests",
    "typecheck": "uv run mypy src",
    "test": "uv run pytest",
    "clean": "rm -rf .venv .ruff_cache .mypy_cache .pytest_cache"
  }
}
