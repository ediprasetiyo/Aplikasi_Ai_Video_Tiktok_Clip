generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------- NextAuth.js v5 (Auth.js) -------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  totpSecret    String? // AES-encrypted at rest; null = 2FA disabled

  accounts      Account[]
  sessions      Session[]
  jobs          Job[]
  auditLogs     AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

// ------------------- App-specific -------------------

model Job {
  id             String     @id @default(cuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  sourceType     SourceType
  sourceUrl      String?
  sourceKey      String?
  sourceTitle    String?
  sourceDuration Int?

  config         Json
  status         JobStatus  @default(QUEUED)
  progress       Int        @default(0)
  errorMessage   String?

  clips          Clip[]
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([userId, status])
  @@index([status, createdAt])
}

model Clip {
  id           String   @id @default(cuid())
  jobId        String
  job          Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  startTime    Float
  endTime      Float
  duration     Float
  viralScore   Int
  reason       String
  hookLine     String?

  videoKey     String
  thumbnailKey String?
  subtitleKey  String?

  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@index([jobId, viralScore])
  @@index([expiresAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  // nullable: failed login attempts on unknown email
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  resource  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

enum SourceType {
  UPLOAD
  URL
}

enum JobStatus {
  QUEUED
  DOWNLOADING
  TRANSCRIBING
  SCORING
  RENDERING
  COMPLETED
  FAILED
}
