# ============================================
# COPY ke .env.local, ISI dengan nilai asli.
# JANGAN PERNAH COMMIT .env.local
# ============================================

# Database
DATABASE_URL="postgresql://postgres:dev@localhost:5432/tiktok_clip"

# Auth.js / NextAuth v5
AUTH_URL="http://localhost:3000"
AUTH_SECRET=""                                # generate: openssl rand -base64 32

# Internal API (shared antara Next API <-> Nest <-> Worker)
INTERNAL_API_SECRET=""                        # generate: openssl rand -base64 32
API_BASE_URL="http://localhost:4000"
WORKER_BASE_URL="http://localhost:8000"

# Redis (BullMQ queue, rate limit, Celery broker)
REDIS_URL="redis://localhost:6379"

# Upstash Redis (rate limit di production)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Cloudflare R2 (atau MinIO lokal)
R2_ENDPOINT="http://localhost:9000"           # MinIO lokal
R2_ACCESS_KEY_ID="minioadmin"
R2_SECRET_ACCESS_KEY="minioadmin"
R2_BUCKET="tiktok-clips"
R2_PUBLIC_URL=""                              # CDN URL kalau ada

# Groq (AI scoring)
GROQ_API_KEY=""                               # daftar gratis di console.groq.com

# SMTP magic link
# DEV: Mailpit di docker-compose (host=localhost, port=1025, no auth)
# PROD: Resend (host=smtp.resend.com, port=465, user=resend, pass=<api-key>)
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@tiktok-clip.local"

# Sentry (opsional)
SENTRY_DSN_WEB=""
SENTRY_DSN_API=""
SENTRY_DSN_WORKER=""

# Worker
WHISPER_MODEL="small"                         # tiny | base | small | medium | large-v3
WHISPER_DEVICE="cpu"
WHISPER_CPU_THREADS="4"
